# ═══════════════════════════════════════════════════════════════════════════
# Operis backend — environment variable template
# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANT: this file is committed to git. Use placeholders only.
# Never paste real tokens, keys, or service-role JWTs here.
# Set actual values in Railway (production) and a local untracked .env file.
# ═══════════════════════════════════════════════════════════════════════════

# Supabase
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-jwt-here
SUPABASE_ANON_KEY=your-supabase-anon-jwt-here

# Vapi
VAPI_API_KEY=your-vapi-api-key-here
# Shared secret sent in X-Operis-Vapi-Secret header on /booking tool calls.
# Generate: openssl rand -hex 32
VAPI_TOOL_SECRET=your-vapi-tool-secret-here
# Shared secret sent in X-Vapi-Secret header on /call/vapi-callback.
# Configure the same value on your Vapi assistant's server config.
# Generate: openssl rand -hex 32
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret-here

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number-e164

# Stripe (deferred — not yet wired)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Cartesia voices (Thai + English) — get IDs from your Cartesia console
CARTESIA_VOICE_TH=your-cartesia-th-voice-id
CARTESIA_VOICE_EN=your-cartesia-en-voice-id

# Demo (founder-controlled shared Vapi assistant)
DEMO_VAPI_AGENT_ID=your-demo-vapi-agent-id
DEMO_TWILIO_NUMBER=your-demo-twilio-number-e164

# Founder-only admin gate for /provision
# Generate: openssl rand -hex 32
ADMIN_TOKEN=your-admin-token-here

# Public-facing URL of this Railway deployment (used for Twilio signature
# verification — must match exactly what Twilio is configured to call).
# e.g. https://operis-backend-production-3533.up.railway.app
BASE_URL=

# Misc
FRONTEND_URL=http://localhost:3001
NODE_ENV=development
PORT=3000
